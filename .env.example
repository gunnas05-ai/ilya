# ═══════════════════════════════════════════════
# KAPTAN Lojistik Platformu — Environment Variables
# ═══════════════════════════════════════════════
# Bu dosyayi .env olarak kopyalayip degerleri doldurun.
# cp .env.example .env

# ── Node Environment ──────────────────────────
NODE_ENV=development

# ── Database (PostgreSQL + PostGIS) ───────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=kaptan
DB_PASS=change-me-in-production
DB_NAME=kaptan
DB_SYNCHRONIZE=false
USE_POSTGIS=true

# ── Redis ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379

# ── JWT Secrets ───────────────────────────────
# openssl rand -hex 64
JWT_SECRET=change-me-use-random-64-char-hex
JWT_REFRESH_SECRET=change-me-use-different-random-hex

# ── Transaction Signing ───────────────────────
TX_SIGNING_SECRET=change-me-use-random-hex

# ── QR Code Security ──────────────────────────
QR_HMAC_SECRET=change-me-use-random-hex

# ── Encryption ────────────────────────────────
ENCRYPTION_KEY=change-me-use-32-char-random-string

# ── CORS ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:3005

# ── Kafka ─────────────────────────────────────
# KAFKA_BROKERS=localhost:9092

# ── MinIO (Object Storage) ────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=kaptan_admin
MINIO_ROOT_PASSWORD=change-me-in-production
# MINIO_ACCESS_KEY — same as MINIO_ROOT_USER
# MINIO_SECRET_KEY — same as MINIO_ROOT_PASSWORD

# ── Payment Gateway (Iyzico) ──────────────────
# IYZICO_API_KEY=sandbox-api-key
# IYZICO_SECRET_KEY=sandbox-secret-key
# IYZICO_BASE_URL=https://sandbox-api.iyzico.com

# ── Commission / Fee Rates ────────────────────
# PLATFORM_COMMISSION_RATE=0.035
# ESCROW_FEE_RATE=0.02
# VAT_RATE=0.20

# ── SMS Provider (Netgsm / Twilio) ────────────
# SMS_PROVIDER=netgsm
# NETGSM_USERCODE=your-usercode
# NETGSM_PASSWORD=your-password
# NETGSM_HEADER=KAPTAN

# ── Service Name ──────────────────────────────
SERVICE_NAME=kaptan-monolith

# ── Instant Booking ───────────────────────────
# INSTANT_BOOK_LOCK_MINUTES=5
