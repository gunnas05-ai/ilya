{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "cross-env REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.34 expo start",
    "start:tunnel": "expo start --tunnel",
    "start:local": "expo start --localhost",
    "android": "cross-env REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.34 expo start --android",
    "ios": "cross-env REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.34 expo start --ios",
    "web": "expo start --web",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "npx tsc --noEmit",
    "detox:build:android": "npx expo prebuild && npx detox build --configuration android.debug",
    "detox:build:ios": "npx expo prebuild && npx detox build --configuration ios.debug",
    "detox:test:android": "npx detox test --configuration android.debug",
    "detox:test:ios": "npx detox test --configuration ios.debug",
    "detox:test:smoke": "npx detox test --configuration android.debug e2e/smoke.test.ts"
  },
  "dependencies": {
